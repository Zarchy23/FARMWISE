# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.onrender.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/farmwise_db
DB_NAME=farmwise_db
DB_USER=postgres
DB_PASSWORD=your-database-password-here
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
# Option 1: Gmail SMTP (Development)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@farmwise.com

# Option 2: SendGrid (Production)
# Uncomment and use these for production with SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Stripe (Payment Processing)
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI (AI Features - DEPRECATED, use free alternatives)
OPENAI_API_KEY=sk-your-openai-key-here

# AI Services (Free tiers available)
GEMINI_API_KEY=your-gemini-api-key-here  # Free tier for Pest Detection
GROQ_API_KEY=your-groq-api-key-here
TOGETHER_API_KEY=your-together-api-key-here
GOOGLE_VISION_API_KEY=your-google-vision-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here  # Free inference API
REPLICATE_API_KEY=your-replicate-api-key-here  # Free tier available

# Social Authentication
GOOGLE_OAUTH_ID=your-google-client-id
GOOGLE_OAUTH_SECRET=your-google-oauth-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# AWS S3 (Optional - for static/media files in production)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Redis (Celery, Caching)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Django Allauth
ACCOUNT_EMAIL_VERIFICATION=mandatory

# Backup Alerts
ALERT_EMAIL=admin@farmwise.com

# Production Settings
IS_PRODUCTION=False
DISABLE_GEMINI_ON_PRODUCTION=False

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
